generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//* USER MODEL
model User {
  id              String   @id @unique
  name            String?
  email           String   @unique
  password        String
  profileImageUrl String?
  isEmailVerified Boolean? @default(false)
  isInstructor    Boolean? @default(false)

  // TOKENS
  refreshTokenGenerationTime DateTime? @default(now())
  refreshToken               String?
  refreshTokenExpiry         String?
  refreshTokenStatus         String?
  accessTokenGenerationTime  DateTime? @default(now())
  accessToken                String?
  accessTokenExpiry          String?
  accessTokenStatus          String?
  resetTokenGenerationTime   DateTime? @default(now())
  resetToken                 String?
  resetTokenExpiry           String?
  resetTokenStatus           String?

  // STRIPE
  stripeCustomerId       String?   @unique @map(name: "stripe_customer_id")
  stripeSubscriptionId   String?   @unique @map(name: "stripe_subscription_id")
  stripePriceId          String?   @map(name: "stripe_price_id")
  stripeCurrentPeriodEnd DateTime? @map(name: "stripe_current_period_end")

  // relations
  wishList     WishList[]
  cart         Cart[]
  enrollments Enrollment[]
  payments     Payment[]
  savedCourses Course[]
  BlogComment  BlogComment[]
  Blog         Blog[]
  Review       Review[]
}

model StripeCustomer {
  stripeCustomerId       String    @id
  userId                 String    @unique
  stripeSubscriptionId   String?
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now())
}

//* CART MODELS
model Cart {
  id        String     @id
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  cartItems CartItem[]
}

model CartItem {
  id                   String    @id @unique
  userId               String
  courseId             String
  courseName           String
  courseInstructorName String
  courseImageUrl       String?
  coursePrice          String
  quantity             Int       @default(1)
  createdAt            DateTime? @default(now())
  updatedAt            DateTime? @default(now()) @updatedAt
  cart                 Cart?     @relation(fields: [id], references: [id])
}

//* WISHLIST MODEL
model WishList {
  userId          String   @id
  wishListedItems String[]
  user            User?    @relation(fields: [userId], references: [id])
}

//? COURSE MODELS
model Course {
  courseId                       String    @id
  courseTitle                    String
  courseImage                    String
  courseCreator                  String
  courseDescription              String?
  isFree                         Boolean   @default(false)
  coursePrice                    String
  dealPrice                      String?
  discount                       String?
  instructorID                   String?
  isLive                         Boolean?  @default(false)
  courseCategories               String[]
  instructorName                 String?
  isPublished                    Boolean?  @default(false)
  avgStarRatings                 Float?    @default(5.0)
  courseDuration                 String?   @default("1 hour 50 minutes")
  technologiesYouAreGoingToLearn String[]  @default(["Flutter", "Node.js", "Next.js"])
  thisCourseIsFor                String[]  @default(["Who wants to learn.", "Want to understand concepts of this topic.", "If you are a enthusiast of subject."])
  prerequisits                   String[]  @default(["Must have a good internet connection.", "Laptop is a must.", "And if you Want to learn & gain knowledge"])
  whatYouWillLearn               String[]  @default(["How to configure and setup open source project", "How to maintain open source codebase"])
  categoryId                     String?
  createdAt                      DateTime? @default(now())
  updatedAt                      DateTime? @default(now())
  userId                         String?

  reviews                          Review[]
  enrollments                     Enrollment[]
  payments                         Payment[]
  purchases                        Purchase[]
  attachments                      CourseAttachment[]
  courseSections                   CourseSection[]
  categories                       Category[]
  chapters                         Chapter[]
  instructorEarningsFromThisCourse InstructorEarning[]

  Instructor Instructor? @relation(fields: [instructorID], references: [instructorID])
  User       User?       @relation(fields: [userId], references: [id])
}

model Review {
  id        String    @id @unique
  rating    Float
  comment   String
  userId    String
  courseId  String
  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now())

  Course Course? @relation(fields: [courseId], references: [courseId])
  User   User?   @relation(fields: [userId], references: [id])
}

model CourseAttachment {
  id   String @id @default(uuid())
  name String @unique
  url  String @db.Text

  courseId String
  course   Course @relation(fields: [courseId], references: [courseId], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
}

model MuxData {
  id         String  @id @default(uuid())
  assetId    String
  playbackId String?

  chapterId String  @unique
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

model CourseSection {
  courseSectionId          String    @id
  courseId                 String    @unique
  instructorId             String
  courseSectionNumber      Int
  courseSectionTitle       String
  courseSectionDescription String?
  course                   Course?   @relation(fields: [courseId], references: [courseId])
  chapters                 Chapter[]
}

model Chapter {
  id              String  @id @default(uuid())
  title           String
  description     String? @db.Text
  videoUrl        String? @db.Text
  position        Int
  isPublished     Boolean @default(false)
  isFree          Boolean @default(false)
  chapterDuration String? @default("03:00")

  muxData MuxData?

  courseId String
  course   Course @relation(fields: [courseId], references: [courseId], onDelete: Cascade)

  userProgress UserProgress[]
  chapterNotes ChapterNotes[]

  createdAt                    DateTime       @default(now())
  updatedAt                    DateTime       @updatedAt
  courseSection                CourseSection? @relation(fields: [courseSectionCourseSectionId], references: [courseSectionId])
  courseSectionCourseSectionId String?

  @@index([courseId])
}

model ChapterNotes {
  noteId    String @id @unique
  userId    String
  courseId  String
  chapterId String
  note      String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  Chapter   Chapter  @relation(fields: [chapterId], references: [id])
}

model Enrollment {
  enrollmentId     String   @id
  userId           String
  courseId         String
  enrollmentDate   String
  completionStatus String
  user             User?    @relation(fields: [userId], references: [id])
  course           Course?  @relation(fields: [courseId], references: [courseId])
}

model UserProgress {
  id     String @id @default(uuid())
  userId String

  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  isCompleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, chapterId])
  @@index([chapterId])
}

//! PAYMENT MODELS
model Subscription {
  id                     String    @id @unique
  userId                 String
  stripeCustomerId       String    @unique
  stripeSubscriptionId   String
  stripePriceId          String
  stripeCurrentPeriodEnd DateTime? @default(now())

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now())
}

model Payment {
  paymentId     String        @id @unique // Primaru Key
  userId        String        @unique // UserID (Foreign Key to User)
  courseId      String        @unique // CourseID (Foreign Key to Course)
  paymentDate   DateTime      @default(now())
  amount        String
  paymentMethod String?
  transactionId String?       @unique
  user          User?         @relation(fields: [userId], references: [id])
  course        Course?       @relation(fields: [courseId], references: [courseId])
  transaction   Transaction[]
}

model Purchase {
  id       String @id @unique @default(uuid())
  userId   String @unique
  courseId String @unique
  amount   String

  course Course @relation(fields: [courseId], references: [courseId], onDelete: Cascade)

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt()

  @@unique([userId, courseId])
  @@index([courseId])
}

model Transaction {
  transactionId     String   @id // (Primary Key)
  paymentId         String // (Foreign Key to Payment)
  transactionDate   DateTime @default(now())
  transactionAmount String
  transactionStatus String
  payment           Payment? @relation(fields: [paymentId], references: [paymentId])
}

//? Category MODEL
model Category {
  name    String   @id
  courses Course[]
  blogs   Blog[]
}

//* BLOG MODELS
model Blog {
  id                   String        @id @unique
  title                String
  content              Json
  estimatedReadingTime String
  clapsCount           BigInt?       @default(0)
  comments             BlogComment[]
  categoryName         String?
  category             Category?     @relation(fields: [categoryName], references: [name])
  authorId             String
  author               User?         @relation(fields: [authorId], references: [id])

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now())
}

model BlogComment {
  id        String    @id @default(cuid())
  blogId    String
  content   String
  authorId  String
  blog      Blog      @relation(fields: [blogId], references: [id])
  author    User?     @relation(fields: [authorId], references: [id])
  writtenOn DateTime? @default(now())
  editedOn  DateTime? @default(now())
}

//* INSTRUCTOR MODELS
model Instructor {
  instructorID            String              @id
  instructorName          String
  instructorEmail         String
  instructorTag           String
  instructorProfilePicUrl String
  aboutInstructor         String?
  createdCourses          Course[]
  earnings                InstructorEarning[]
}

model InstructorEarning {
  earningId     String      @id
  instructorId  String
  courseId      String
  earningDate   String
  earningAmount String
  instructor    Instructor? @relation(fields: [instructorId], references: [instructorID])
  course        Course?     @relation(fields: [courseId], references: [courseId])
}
