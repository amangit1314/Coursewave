generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// --------------------------- USER & AUTH -------------------------------
model User {
  id              String        @id @default(uuid())
  name            String?
  email           String        @unique
  password        String
  profileImageUrl String?
  about           String?
  shortSummary    String?
  slug            String?       @unique
  isEmailVerified Boolean       @default(false)
  preferences     Json          @default("{}")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  authoredBlogs   Blog[]
  blogComments    BlogComment[]

  csrfTokens CSRFToken[]

  courseProgress    CourseProgress[]
  enrollments       Enrollment[]
  instructorProfile Instructor?
  payments          Payment[]
  reviews           Review[]
  stripeCustomer    StripeCustomer?
  tokens            Token[]
  roles             UserRole[]
  subscription      UserSubscription?

  followers UserFollower[] @relation("UserFollowers")
  following UserFollower[] @relation("UserFollowing")

  savedArticles   SavedArticle[]
  blogLikes       BlogLike[]
  blogViews       BlogView[]
  coursePurchases CoursePurchase[]

  chapterNotes      ChapterNote[]
  chapterProgresses ChapterProgress[]
  commentLikes      CommentLike[]
  communityMembers  CommunityMember[]
  messages          Message[]
  moderationLogs    ModerationLog[]
  pinnedMessages    PinnedMessage[]
  reactions         Reaction[]

  projectSubmissions ProjectSubmission[]

  sessionBookings SessionBooking[]

  Cart       Cart?
  Wishlist   Wishlist?
  BlogReport BlogReport[]

  @@index([email])
  @@index([createdAt])
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
}

model UserFollower {
  userId     String   @id
  followerId String
  createdAt  DateTime @default(now())

  user     User @relation("UserFollowers", fields: [userId], references: [id], onDelete: Cascade)
  follower User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)

  @@unique([userId, followerId])
  @@map("user_followers")
}

model Token {
  id        String      @id @default(uuid())
  userId    String
  type      TokenType
  value     String
  status    TokenStatus @default(ACTIVE)
  expiresAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model CSRFToken {
  id        String   @id @default(uuid())
  userId    String
  token     String
  purpose   String
  expiresAt DateTime
  used      Boolean  @default(false)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([purpose])
  @@index([expiresAt])
}

/// --------------------------- BLOG SYSTEM -------------------------------
model Blog {
  id           String         @id @default(uuid())
  title        String
  content      String
  slug         String         @unique
  excerpt      String?
  coverImage   String?
  readTime     Int?
  isPublished  Boolean        @default(false)
  publishedAt  DateTime?
  tags         String[]
  authorId     String
  categoryId   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  author       User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  Category     Category?      @relation(fields: [categoryId], references: [id])
  comments     BlogComment[]
  BlogLike     BlogLike[]
  BlogView     BlogView[]
  SavedArticle SavedArticle[]
  BlogReport   BlogReport[]

  @@index([slug])
  @@index([authorId])
  @@index([isPublished])
  @@index([categoryId])
}

model BlogReport {
  id         String   @id @default(uuid())
  blogId     String
  reporterId String
  reason     String
  details    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  blog       Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([blogId])
  @@index([reporterId])
}

model BlogComment {
  id          String        @id @default(uuid())
  content     String
  blogId      String
  authorId    String
  parentId    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  blog        Blog          @relation(fields: [blogId], references: [id], onDelete: Cascade)
  parent      BlogComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     BlogComment[] @relation("CommentReplies")
  CommentLike CommentLike[]

  @@index([blogId])
  @@index([authorId])
  @@index([parentId])
}

model BlogLike {
  id        String   @id
  blogId    String
  userId    String
  createdAt DateTime @default(now())
  Blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([blogId, userId])
  @@index([blogId])
  @@index([userId])
}

model BlogView {
  id        String   @id
  blogId    String
  userId    String?
  ip        String?
  createdAt DateTime @default(now())
  Blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  User      User?    @relation(fields: [userId], references: [id])

  @@index([blogId])
  @@index([userId])
}

model CommentLike {
  id          String       @id
  commentId   String
  userId      String
  type        ReactionType @default(LIKE)
  createdAt   DateTime     @default(now())
  BlogComment BlogComment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  User        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model SavedArticle {
  userId  String
  blogId  String
  savedAt DateTime @default(now())
  blog    Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, blogId])
}

model Course {
  isFree            Boolean             @default(false)
  instructorId      String?
  isLive            Boolean             @default(false)
  isPublished       Boolean             @default(false)
  categoryId        String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  averageRating     Float?              @default(0.0)
  categories        String[]
  description       String?
  duration          Int?
  id                String              @id @default(uuid())
  slug              String              @unique
  imageUrl          String?
  learningOutcomes  String[]
  prerequisites     String[]
  price             Float               @default(0)
  targetAudience    String[]
  technologies      String[]
  title             String
  dealPrice         Float               @default(0)
  discount          Float               @default(0)
  CartItem          CartItem[]
  Chapter           Chapter[]
  Category          Category?           @relation(fields: [categoryId], references: [id])
  instructor        Instructor?         @relation(fields: [instructorId], references: [userId])
  CourseAttachment  CourseAttachment[]
  CourseProgress    CourseProgress[]
  CoursePurchase    CoursePurchase[]
  sections          CourseSection[]
  Enrollment        Enrollment[]
  InstructorEarning InstructorEarning[]
  Payment           Payment[]
  Project           Project[]
  Review            Review[]
  Wishlist          Wishlist[]          @relation("CourseToWishlist")

  @@index([instructorId])
  @@index([isPublished])
  @@index([averageRating])
  @@index([categoryId])
  @@index([price])
}

model CourseSection {
  id          String    @id @default(uuid())
  title       String
  description String?
  position    Int
  courseId    String
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  Chapter     Chapter[]
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([position])
}

model Chapter {
  id              String             @id
  slug            String?            @unique
  title           String
  description     String?
  position        Int
  sectionId       String
  courseId        String
  isPublished     Boolean            @default(false)
  isFree          Boolean            @default(false)
  content         Json?
  createdAt       DateTime?          @default(now())
  updatedAt       DateTime?          @updatedAt
  contentType     ChapterContentType @default(VIDEO)
  Course          Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  CourseSection   CourseSection      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  ChapterNote     ChapterNote[]
  ChapterProgress ChapterProgress[]
  videoMetadata   VideoAsset?

  @@index([courseId])
  @@index([position])
  @@index([sectionId])
}

model VideoAsset {
  id           String        @id @default(uuid())
  chapterId    String        @unique
  provider     VideoProvider @default(SUPABASE)
  publicId     String
  secureUrl    String
  format       String
  duration     Int?
  width        Int?
  height       Int?
  bytes        Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  bitrate      Int?
  chapters     Json?
  codec        String?
  framerate    Float?
  subtitlesUrl String?
  thumbnailUrl String?
  Chapter      Chapter       @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

model ChapterNote {
  id        String   @id
  content   String
  chapterId String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime
  Chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@index([userId])
}

model ChapterProgress {
  id               String          @id
  chapterId        String
  userId           String
  courseProgressId String?
  enrollmentId     String?
  isCompleted      Boolean         @default(false)
  progress         Int             @default(0)
  lastAccessed     DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  Chapter          Chapter         @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  CourseProgress   CourseProgress? @relation(fields: [courseProgressId], references: [id])
  Enrollment       Enrollment?     @relation(fields: [enrollmentId], references: [id])
  User             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chapterId, userId])
  @@index([chapterId])
  @@index([courseProgressId])
  @@index([enrollmentId])
  @@index([userId])
}

model CourseProgress {
  id              String            @id @default(uuid())
  courseId        String
  userId          String
  isCompleted     Boolean           @default(false)
  progress        Int               @default(0)
  lastAccessed    DateTime          @default(now())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  ChapterProgress ChapterProgress[]
  Course          Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  User            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
}

model CourseAttachment {
  id           String     @id
  name         String
  url          String
  instructorId String
  courseId     String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  Course       Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  Instructor   Instructor @relation(fields: [instructorId], references: [userId])

  @@index([courseId])
  @@index([instructorId])
}

model CoursePurchase {
  id              String        @id
  userId          String
  courseId        String
  amount          Float
  currency        String        @default("USD")
  status          PaymentStatus
  paymentMethod   PaymentMethod
  stripePaymentId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  Course          Course        @relation(fields: [courseId], references: [id])
  User            User          @relation(fields: [userId], references: [id])

  @@index([courseId])
  @@index([status])
  @@index([userId])
}

model Enrollment {
  id              String            @id @default(uuid())
  userId          String
  courseId        String
  status          EnrollmentStatus  @default(ACTIVE)
  progress        Int               @default(0)
  startDate       DateTime          @default(now())
  endDate         DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  ChapterProgress ChapterProgress[]
  course          Course            @relation(fields: [courseId], references: [id])
  user            User              @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model Review {
  id        String   @id @default(uuid())
  rating    Float
  comment   String
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([rating])
}

model Cart {
  id        String     @id
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime
  User      User       @relation(fields: [userId], references: [id])
  CartItem  CartItem[]

  @@index([userId])
}

model CartItem {
  id        String   @id
  courseId  String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime
  cartId    String
  Cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  Course    Course   @relation(fields: [courseId], references: [id])

  @@unique([cartId, courseId])
  @@index([cartId])
  @@index([courseId])
}

model Wishlist {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime
  userId    String   @unique
  User      User     @relation(fields: [userId], references: [id])
  Course    Course[] @relation("CourseToWishlist")
}

model Payment {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  amount    Float
  currency  String   @default("USD")
  status    String
  paymentId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([courseId])
}

/// -------------------- Community & Chat --------------------------
model Community {
  id             String            @id @default(uuid())
  slug           String?           @unique
  title          String
  description    String?
  tags           String[]
  categoryId     String
  isPublic       Boolean           @default(true)
  isFeatured     Boolean           @default(false)
  isTrending     Boolean           @default(false)
  isPopular      Boolean           @default(false)
  avatarUrls     String[]
  thumbnailUrl   String?
  bannerUrl      String?
  lastActiveAt   DateTime          @default(now())
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  category       Category          @relation(fields: [categoryId], references: [id])
  members        CommunityMember[]
  messages       Message[]
  ModerationLog  ModerationLog[]
  pinnedMessages PinnedMessage[]
}

/// Manages the relationship between a user and a community, including their role
model CommunityMember {
  id               String        @id @default(uuid())
  userId           String
  communityId      String
  role             CommunityRole @default(MEMBER)
  joinedAt         DateTime      @default(now())
  lastReadAt       DateTime      @default(now())
  isArchivedByUser Boolean       @default(false)
  isOnline         Boolean       @default(true)
  community        Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
}

model Message {
  id            String         @id @default(uuid())
  communityId   String
  senderId      String
  slug          String         @unique
  content       String?
  attachments   Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  isPinned      Boolean        @default(false)
  parentId      String?
  community     Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  parentMessage Message?       @relation("MessageReplies", fields: [parentId], references: [id])
  replies       Message[]      @relation("MessageReplies")
  sender        User           @relation(fields: [senderId], references: [id], onDelete: Cascade)
  PinnedMessage PinnedMessage?
  reactions     Reaction[]
}

model Reaction {
  id        String       @id @default(uuid())
  messageId String
  userId    String
  type      ReactionType
  createdAt DateTime     @default(now())
  message   Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, type])
  @@index([messageId])
  @@index([userId])
}

model PinnedMessage {
  id             String    @id @default(uuid())
  communityId    String
  messageId      String    @unique
  pinnedByUserId String
  pinnedAt       DateTime  @default(now())
  community      Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  message        Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedByUser   User      @relation(fields: [pinnedByUserId], references: [id], onDelete: Cascade)
}

model ModerationLog {
  id              String    @id @default(uuid())
  moderatorId     String
  communityId     String
  action          String
  targetUserId    String?
  targetMessageId String?
  reason          String?
  createdAt       DateTime  @default(now())
  community       Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  moderator       User      @relation(fields: [moderatorId], references: [id], onDelete: Cascade)
}

model SubscriptionPlan {
  id                      String                   @id @default(uuid())
  slug                    String?                  @unique
  stripePriceId           String?                  @unique
  name                    String
  type                    PlanType
  price                   Float
  currency                String                   @default("USD")
  interval                Interval                 @default(MONTHLY)
  whatIncludes            String[]
  features                Json                     @default("{}")
  isActive                Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  instructorSubscriptions InstructorSubscription[]
  userSubscriptions       UserSubscription[]

  @@index([isActive])
  @@index([price])
  @@index([type])
}

model UserSubscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  slug                 String?            @unique
  planId               String
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  endedAt              DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime
  plan                 SubscriptionPlan   @relation(fields: [planId], references: [id])
  // StripeCustomer       StripeCustomer     @relation(fields: [stripeCustomerId], references: [id])
  StripeCustomer       StripeCustomer     @relation(fields: [stripeCustomerId], references: [stripeCustomerId])

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([currentPeriodEnd])
  @@index([planId])
  @@index([status])
}

model StripeCustomer {
  stripeCustomerId       String            @unique
  userId                 String            @unique
  stripeSubscriptionId   String?           @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  id                     String            @id @default(uuid())
  user                   User              @relation(fields: [userId], references: [id])
  UserSubscription       UserSubscription?
}

model Project {
  id               String              @id @default(uuid())
  slug             String?             @unique
  title            String
  description      String
  courseId         String
  instructorId     String
  thumbnailUrl     String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deadline         DateTime?
  maxSubmissions   Int?
  status           ProjectStatus       @default(PUBLISHED)
  difficulty       ProjectDifficulty?
  isPublic         Boolean             @default(false)
  startDate        DateTime?
  endDate          DateTime?
  categories       String[]
  tags             String[]
  prerequisites    String[]
  technologies     String[]
  learningOutcomes String[]
  resources        String[]
  course           Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructor       Instructor          @relation(fields: [instructorId], references: [userId])
  submissions      ProjectSubmission[]

  @@index([courseId])
  @@index([instructorId])
}

model ProjectSubmission {
  id            String           @id @default(uuid())
  projectId     String
  studentId     String
  submissionUrl String
  submittedAt   DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  feedback      ProjectFeedback?
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  student       User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([projectId, studentId])
  @@index([projectId])
  @@index([studentId])
}

model ProjectFeedback {
  id           String            @id @default(uuid())
  submissionId String            @unique
  instructorId String
  feedbackText String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  instructor   Instructor        @relation(fields: [instructorId], references: [userId])
  submission   ProjectSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

/// --------------------------------------- CATEGORY ------------------------------------
model Category {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  Blog        Blog[]
  Community   Community[]
  Course      Course[]

  @@index([name])
}

/// --------------------------------------- INSTRUCTOR -----------------------
model Instructor {
  userId           String                  @id @unique
  slug             String?                 @unique
  bio              String?
  expertise        String[]
  socialLinks      Json?                   @default("{}")
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  courses          Course[]
  CourseAttachment CourseAttachment[]
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  earnings         InstructorEarning[]
  subscription     InstructorSubscription?
  Project          Project[]
  ProjectFeedback  ProjectFeedback[]
  Session          Session[]
  SessionBooking   SessionBooking[]

  @@index([userId])
}

model InstructorSubscription {
  id                   String             @id @default(uuid())
  instructorId         String             @unique
  planId               String
  // stripeAccountId      String?
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?            @unique
  stripePriceId        String?
  slug                 String?
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  endedAt              DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime
  instructor           Instructor         @relation(fields: [instructorId], references: [userId], onDelete: Cascade)
  plan                 SubscriptionPlan   @relation(fields: [planId], references: [id])

  @@index([planId])
  @@index([status])
}

model InstructorEarning {
  id           String     @id @default(uuid())
  instructorId String
  courseId     String
  amount       Float
  currency     String     @default("USD")
  status       String
  paymentId    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  course       Course     @relation(fields: [courseId], references: [id])
  instructor   Instructor @relation(fields: [instructorId], references: [userId])

  @@index([instructorId])
  @@index([status])
  @@index([courseId])
}

model Session {
  id           String           @id
  slug         String?          @unique
  title        String
  description  String?
  imageUrl     String?
  status       SessionStatus    @default(UPCOMING)
  type         SessionType      @default(ONE_TO_ONE)
  rtcType      RtcType          @default(WEBRTC)
  rtcRoomId    String
  rtcToken     String?
  rtcConfig    Json?
  isFree       Boolean          @default(false)
  price        Float?
  currency     String           @default("USD")
  scheduledAt  DateTime
  duration     Int
  endsAt       DateTime
  instructorId String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  Instructor   Instructor       @relation(fields: [instructorId], references: [userId])
  bookings     SessionBooking[]

  @@index([instructorId])
  @@index([scheduledAt])
  @@index([status])
}

model SessionBooking {
  id               String         @id @default(uuid())
  sessionId        String
  userId           String
  paymentStatus    PaymentStatus  @default(PENDING)
  amountPaid       Float?
  paymentMethod    PaymentMethod?
  stripePaymentId  String?
  joinedAt         DateTime?
  leftAt           DateTime?
  durationAttended Int?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  instructorId     String?
  Instructor       Instructor?    @relation(fields: [instructorId], references: [userId])
  session          Session        @relation(fields: [sessionId], references: [id])
  user             User           @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
  @@index([paymentStatus])
}

